{
  "openapi": "3.0.1",
  "info": {
    "title": "校园周边商城 - 订单模块 API",
    "version": "1.0.0"
  },
  "servers": [
    { "url": "http://127.0.0.1:8000/api" }
  ],
  "tags": [
    { "name": "认证" },
    { "name": "订单" },
    { "name": "审核" }
  ],
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "Token"
      }
    }
  },
  "paths": {
    "/register": {
      "post": {
        "tags": ["认证"],
        "summary": "用户注册",
        "operationId": "register",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name", "email", "password", "password_confirmation"],
                "properties": {
                  "name": { "type": "string", "example": "张三" },
                  "email": { "type": "string", "format": "email", "example": "zhangsan@example.com" },
                  "password": { "type": "string", "format": "password", "example": "12345678" },
                  "password_confirmation": { "type": "string", "format": "password", "example": "12345678" },
                  "phone": { "type": "string", "example": "13800138000" }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "注册成功",
            "content": {
              "application/json": {
                "example": {
                  "code": 0,
                  "message": "success",
                  "data": {
                    "token": "1|abc123def456",
                    "token_type": "Bearer",
                    "user": {
                      "id": 1,
                      "name": "张三",
                      "email": "zhangsan@example.com",
                      "phone": "13800138000",
                      "role": "user",
                      "status": "active"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/login": {
      "post": {
        "tags": ["认证"],
        "summary": "用户登录(限速5次/分钟)",
        "operationId": "login",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email", "password"],
                "properties": {
                  "email": { "type": "string", "format": "email", "example": "zhangsan@example.com" },
                  "password": { "type": "string", "format": "password", "example": "12345678" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "登录成功",
            "content": {
              "application/json": {
                "example": {
                  "code": 0,
                  "message": "success",
                  "data": {
                    "token": "2|xyz789ghi012",
                    "token_type": "Bearer",
                    "user": {
                      "id": 1,
                      "name": "张三",
                      "email": "zhangsan@example.com",
                      "role": "user",
                      "status": "active"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/orders": {
      "post": {
        "tags": ["订单"],
        "summary": "提交预订(下单)",
        "operationId": "orderStore",
        "description": "用户下单，系统自动预扣库存(reserved_stock增加)，状态变为booked。商品必须为上架状态(active)。",
        "security": [{ "BearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["product_id", "quantity"],
                "properties": {
                  "product_id": { "type": "integer", "example": 1 },
                  "quantity": { "type": "integer", "minimum": 1, "maximum": 999, "example": 2 },
                  "size": { "type": "string", "example": "XL" },
                  "color": { "type": "string", "example": "白色" },
                  "shipping_address": { "type": "string", "example": "北京市海淀区XX路XX号" },
                  "remark": { "type": "string", "example": "请加急处理" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "下单成功",
            "content": {
              "application/json": {
                "example": {
                  "code": 0,
                  "message": "下单成功",
                  "data": {
                    "id": 1,
                    "order_no": "ORD202604281000000001",
                    "user_id": 1,
                    "product_id": 1,
                    "quantity": 2,
                    "unit_price": "59.90",
                    "total_price": "119.80",
                    "size": "XL",
                    "color": "白色",
                    "status": "booked",
                    "shipping_address": "北京市海淀区XX路XX号",
                    "remark": "请加急处理",
                    "reviewed_by": null,
                    "reviewed_at": null,
                    "review_reason": null,
                    "completed_at": null,
                    "created_at": "2026-04-28T10:00:00.000000Z",
                    "updated_at": "2026-04-28T10:00:00.000000Z"
                  }
                }
              }
            }
          },
          "422": {
            "description": "库存不足或参数校验失败",
            "content": {
              "application/json": {
                "example": {
                  "message": "The given data was invalid.",
                  "errors": { "quantity": ["库存不足"] }
                }
              }
            }
          }
        }
      }
    },
    "/my-orders": {
      "get": {
        "tags": ["订单"],
        "summary": "我的订单",
        "operationId": "myOrders",
        "description": "查询当前用户的订单列表，支持按状态筛选和分页",
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          { "name": "status", "in": "query", "description": "按状态筛选", "schema": { "type": "string", "enum": ["draft", "booked", "design_pending", "ready", "completed", "rejected"] }, "example": "booked" },
          { "name": "per_page", "in": "query", "description": "每页条数", "schema": { "type": "integer", "default": 10 }, "example": 10 },
          { "name": "page", "in": "query", "description": "页码", "schema": { "type": "integer", "default": 1 }, "example": 1 }
        ],
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "example": {
                  "code": 0,
                  "message": "success",
                  "data": {
                    "data": [
                      {
                        "id": 1,
                        "order_no": "ORD202604281000000001",
                        "product_id": 1,
                        "quantity": 2,
                        "unit_price": "59.90",
                        "total_price": "119.80",
                        "status": "booked",
                        "shipping_address": "北京市海淀区XX路XX号",
                        "created_at": "2026-04-28T10:00:00.000000Z",
                        "product": { "id": 1, "name": "校园文化衫", "price": "59.90" },
                        "attachments": []
                      }
                    ],
                    "meta": { "current_page": 1, "last_page": 1, "per_page": 10, "total": 1 }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/orders/{order}": {
      "get": {
        "tags": ["订单"],
        "summary": "订单详情",
        "operationId": "orderShow",
        "description": "查看订单详情，仅订单所有者或管理员可查看",
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          { "name": "order", "in": "path", "required": true, "description": "订单ID", "schema": { "type": "integer" }, "example": 1 }
        ],
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "example": {
                  "code": 0,
                  "message": "success",
                  "data": {
                    "id": 1,
                    "order_no": "ORD202604281000000001",
                    "quantity": 2,
                    "unit_price": "59.90",
                    "total_price": "119.80",
                    "status": "booked",
                    "shipping_address": "北京市海淀区XX路XX号",
                    "remark": "请加急处理",
                    "reviewed_by": null,
                    "reviewed_at": null,
                    "review_reason": null,
                    "completed_at": null,
                    "product": { "id": 1, "name": "校园文化衫", "price": "59.90" },
                    "attachments": []
                  }
                }
              }
            }
          }
        }
      }
    },
    "/orders/{order}/complete": {
      "post": {
        "tags": ["订单"],
        "summary": "确认收货/核销",
        "operationId": "orderComplete",
        "description": "仅ready状态可操作。完成后：reserved_stock减少，sold_stock增加（预扣转已售）",
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          { "name": "order", "in": "path", "required": true, "description": "订单ID", "schema": { "type": "integer" }, "example": 1 }
        ],
        "responses": {
          "200": {
            "description": "订单已完成",
            "content": {
              "application/json": {
                "example": {
                  "code": 0,
                  "message": "订单已完成",
                  "data": {
                    "id": 1,
                    "order_no": "ORD202604281000000001",
                    "status": "completed",
                    "completed_at": "2026-04-28T12:00:00.000000Z"
                  }
                }
              }
            }
          },
          "422": {
            "description": "当前状态不可完成",
            "content": {
              "application/json": {
                "example": {
                  "message": "The given data was invalid.",
                  "errors": { "status": ["当前状态不可完成"] }
                }
              }
            }
          }
        }
      }
    },
    "/admin/orders/{order}/review": {
      "put": {
        "tags": ["审核"],
        "summary": "订单审核(管理员)",
        "operationId": "orderReview",
        "description": "仅design_pending状态可审核。approve→ready；reject→rejected并释放预扣库存(reserved_stock减少)。驳回时reason必填。",
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          { "name": "order", "in": "path", "required": true, "description": "订单ID", "schema": { "type": "integer" }, "example": 1 }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["action"],
                "properties": {
                  "action": { "type": "string", "enum": ["approve", "reject"], "description": "approve=通过, reject=驳回", "example": "approve" },
                  "reason": { "type": "string", "description": "驳回原因(驳回时必填)", "example": "设计稿不符合规范，请重新上传" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "审核完成",
            "content": {
              "application/json": {
                "example": {
                  "code": 0,
                  "message": "审核完成",
                  "data": {
                    "id": 1,
                    "order_no": "ORD202604281000000001",
                    "status": "ready",
                    "reviewed_by": 2,
                    "reviewed_at": "2026-04-28T11:00:00.000000Z",
                    "review_reason": null
                  }
                }
              }
            }
          },
          "422": {
            "description": "当前状态不可审核或驳回缺少原因",
            "content": {
              "application/json": {
                "example": {
                  "message": "The given data was invalid.",
                  "errors": { "reason": ["驳回必须填写原因"] }
                }
              }
            }
          }
        }
      }
    }
  }
}